<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42/"
     xml:base="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:agro="http://purl.obolibrary.org/obo/agro/releases/2022-11-02/agro.owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:schema="https://schema.org/Person/"
     xmlns:schema1="http://schema.org/"
     xmlns:untitled-ontology-42="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/suitableForDiet -->

    <owl:ObjectProperty rdf:about="http://schema.org/suitableForDiet">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasSuitableFood"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>Relates a food item to a diet type for which it is suitable or compatible. Domain: Food; Range: Diet.</rdfs:comment>
        <rdfs:label>suitable For Diet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#IsAvoidedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#IsAvoidedIn">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#avoidsFood"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>Inverse of avoidsFood. Relates a food item to the diet plan(s) in which it is restricted or excluded. Domain: Food; Range: Diet.</rdfs:comment>
        <rdfs:label>is Avoided In</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#affectedByDiet -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#affectedByDiet">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#affectsMedicalCondition"/>
        <rdfs:domain rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:range rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>Inverse of affectsMedicalCondition. Relates a medical condition to the diet(s) that influence it. Domain: MedicalCondition; Range: Diet.</rdfs:comment>
        <rdfs:label>affected By Diet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#affectsMedicalCondition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#affectsMedicalCondition">
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:comment>Relates a diet to a medical condition that it impacts, either positively (therapeutic) or negatively. Domain: Diet; Range: MedicalCondition.</rdfs:comment>
        <rdfs:label>affects Medical Condition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#avoidsFood -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#avoidsFood">
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:comment>Relates a diet plan to a food item that is restricted or excluded from that diet. Domain: Diet; Range: Food.</rdfs:comment>
        <rdfs:label>avoids Food</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#followsDiet -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#followsDiet">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isFollowedBy"/>
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>Relates a person to the diet plan they are currently following. Domain: Person; Range: Diet.</rdfs:comment>
        <rdfs:label>follows Diet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasCondition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasCondition">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isConditionOf"/>
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:comment>Relates a person to a medical condition they have been diagnosed with. Domain: Person; Range: MedicalCondition.</rdfs:comment>
        <rdfs:label>has Condition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasMacroNutrient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasMacroNutrient">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isMacroNutrientOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Macronutrient"/>
        <rdfs:comment>Relates a nutritional component to an associated macronutrient. Domain: NutritionInformation; Range: Macronutrient.</rdfs:comment>
        <rdfs:label>has Macro Nutrient</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasMicroNutrient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasMicroNutrient">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isMicroNutrientOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Micronutrient"/>
        <rdfs:comment>Relates a nutritional component to an associated micronutrient such as a vitamin. Domain: NutritionInformation; Range: Micronutrient.</rdfs:comment>
        <rdfs:label>has Micro Nutrient</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasNutritionInfo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasNutritionInfo">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isNutritionInfoOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:comment>Relates a food item to its nutritional information, including macronutrients, micronutrients, minerals, and water content. Domain: Food; Range: NutritionInformation.</rdfs:comment>
        <rdfs:label>has Nutrition Info</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasOrigin -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasOrigin">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isOriginOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#FoodOrigin"/>
        <rdfs:comment>Relates a food item to its geographical origin. Domain: Food; Range: FoodOrigin.</rdfs:comment>
        <rdfs:label>has Origin</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasRecommendedFood -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasRecommendedFood">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendedForCondition"/>
        <rdfs:domain rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasSuitableFood -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hasSuitableFood">
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#includesFood -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#includesFood">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isIncludedInDiet"/>
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:comment>Relates a diet plan to a food item that is included and recommended within that diet. Domain: Diet; Range: Food.</rdfs:comment>
        <rdfs:label>includes Food</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isConditionOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isConditionOf">
        <rdfs:domain rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:range rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>Inverse of hasCondition. Relates a medical condition to the person who has it. Domain: MedicalCondition; Range: Person.</rdfs:comment>
        <rdfs:label>is Condition Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isFollowedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isFollowedBy">
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>Inverse of followsDiet. Relates a diet to the persons who follow it. Domain: Diet; Range: Person.</rdfs:comment>
        <rdfs:label>is Followed By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isIncludedInDiet -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isIncludedInDiet">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>Inverse of includesFood. Relates a food item to the diet plan(s) in which it is included. Domain: Food; Range: Diet.</rdfs:comment>
        <rdfs:label>is Included In Diet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isMacroNutrientOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isMacroNutrientOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Macronutrient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isMicroNutrientOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isMicroNutrientOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Micronutrient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isNutritionInfoOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isNutritionInfoOf">
        <rdfs:domain rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:comment>Inverse of hasNutritionInfo. Relates a nutritional component to the food item(s) it belongs to. Domain: NutritionInformation; Range: Food.</rdfs:comment>
        <rdfs:label>is Nutrition Info Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isOriginOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isOriginOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#FoodOrigin"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:comment>Inverse of hasOrigin. Relates a food origin to the food item(s) that come from that region. Domain: FoodOrigin; Range: Food.</rdfs:comment>
        <rdfs:label>is Origin Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isStudiedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#isStudiedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#studiesNutrition"/>
        <rdfs:domain rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendsDiet"/>
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
        <rdfs:comment>Inverse of recommendsDiet. Relates a diet to the dietitian(s) who recommend it. Domain: Diet; Range: Dietitian.</rdfs:comment>
        <rdfs:label>recommended By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendedForCondition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendedForCondition">
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:comment>Relates a diet plan to a medical condition for which it is clinically recommended or beneficial. Domain: Diet; Range: MedicalCondition.</rdfs:comment>
        <rdfs:label>recommended For Condition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendsDiet -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendsDiet">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
        <rdfs:range rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>Relates a dietitian to a diet plan they professionally recommend to their patients. Domain: Dietitian; Range: Diet.</rdfs:comment>
        <rdfs:label>recommends Diet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#studiesNutrition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#studiesNutrition">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:comment>Relates a person (typically a researcher or student) to nutritional information they are studying or researching. Domain: Person; Range: NutritionInformation.</rdfs:comment>
        <rdfs:label>studies Nutrition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/calories -->

    <owl:DatatypeProperty rdf:about="http://schema.org/calories">
        <rdfs:domain rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>The caloric energy content of a nutritional component, expressed in kilocalories per gram (kcal/g). Domain: NutritionInformation.</rdfs:comment>
        <rdfs:label>calories</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/category -->

    <owl:DatatypeProperty rdf:about="http://schema.org/category">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The food category or classification of a food item, such as dairy, poultry, legume, or leafy-green-vegetables. Domain: Food.</rdfs:comment>
        <rdfs:label>category</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/description -->

    <owl:DatatypeProperty rdf:about="http://schema.org/description">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Diet"/>
                    <rdf:Description rdf:about="http://schema.org/MedicalCondition"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A human-readable textual description of a diet plan or medical condition. Domain: Diet or MedicalCondition.</rdfs:comment>
        <rdfs:label>description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/email -->

    <owl:DatatypeProperty rdf:about="http://schema.org/email">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The email address of a person for contact purposes. Domain: Person; Range: xsd:string.</rdfs:comment>
        <rdfs:label>email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/gender -->

    <owl:DatatypeProperty rdf:about="http://schema.org/gender">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The gender of a person. Accepted values include male, female, or other. Domain: Person; Range: xsd:string.</rdfs:comment>
        <rdfs:label>gender</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/givenName -->

    <owl:DatatypeProperty rdf:about="http://schema.org/givenName">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The given (first) name of a person. Domain: Person; Range: xsd:string.</rdfs:comment>
        <rdfs:label>given Name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/height -->

    <owl:DatatypeProperty rdf:about="http://schema.org/height">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The height of a person, typically expressed in centimetres or metres. Domain: Person; Range: xsd:string.</rdfs:comment>
        <rdfs:label>height</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/name -->

    <owl:DatatypeProperty rdf:about="http://schema.org/name">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Diet"/>
                    <rdf:Description rdf:about="http://schema.org/MedicalCondition"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official name or title of a diet plan or medical condition. Domain: Diet or MedicalCondition; Range: xsd:string.</rdfs:comment>
        <rdfs:label>name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/servingSize -->

    <owl:DatatypeProperty rdf:about="http://schema.org/servingSize">
        <rdfs:domain rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>The recommended daily serving size or percentage of daily value (DV) for a nutritional component. Domain: NutritionInformation.</rdfs:comment>
        <rdfs:label>serving Size</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/weight -->

    <owl:DatatypeProperty rdf:about="http://schema.org/weight">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The body weight of a person, typically expressed in kilograms. Domain: Person; Range: xsd:integer.</rdfs:comment>
        <rdfs:label>weight</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#allergen -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#allergen">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/GSSO_011756"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The specific substance or trigger that causes the allergic reaction, such as peanut-product, dust-mites, or tree-pollen. Domain: Allergy; Range: xsd:string.</rdfs:comment>
        <rdfs:label>allergen</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#animalSource -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#animalSource">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#AnimalBasedFood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The animal from which an animal-based food item is derived, such as chicken, goat, lamb, or hen. Domain: AnimalBasedFood; Range: xsd:string.</rdfs:comment>
        <rdfs:label>animal Source</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#countryOfOrigin -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#countryOfOrigin">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#FoodOrigin"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The country from which a food item or food origin instance originates. Domain: FoodOrigin; Range: xsd:string.</rdfs:comment>
        <rdfs:label>country Of Origin</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#dailyWaterIntakeRecommendation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#dailyWaterIntakeRecommendation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Water"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>The recommended daily intake of water for a healthy adult, typically 2–3 litres per day. Domain: Water; Range: xsd:decimal.</rdfs:comment>
        <rdfs:label>daily Water Intake Recommendation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#deficientNutrient -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#deficientNutrient">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/DOID_5113"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The nutrient whose deficiency causes or is associated with this deficiency disease, e.g., vitamin B12 for anemia. Domain: DeficiencyDisease; Range: xsd:string.</rdfs:comment>
        <rdfs:label>deficient Nutrient</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#diagnosisMethod -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#diagnosisMethod">
        <rdfs:domain rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The medical test or procedure used to diagnose a medical condition, such as CBC, X-ray, blood test, or oral-glucose-tolerance-test. Domain: MedicalCondition; Range: xsd:string.</rdfs:comment>
        <rdfs:label>diagnosis Method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#enrollmentYear -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#enrollmentYear">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The year in which a researcher or student enrolled at their academic institution. Domain: Researcher or Student; Range: xsd:integer.</rdfs:comment>
        <rdfs:label>enrollment Year</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#harvestSeason -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#harvestSeason">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#PlantBasedFood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The season or months during which a plant-based food item is typically harvested, e.g., summer-and-autumn or nov-march. Domain: PlantBasedFood; Range: xsd:string.</rdfs:comment>
        <rdfs:label>harvest Season</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hospitalAffiliation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#hospitalAffiliation">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#HealthcareProfessional"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The name of the hospital or medical facility with which a dietitian or healthcare professional is affiliated. Domain: Dietitian or HealthcareProfessional; Range: xsd:string.</rdfs:comment>
        <rdfs:label>hospital Affiliation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#icdCode -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#icdCode">
        <rdfs:domain rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The International Classification of Diseases (ICD) code assigned to a medical condition by the World Health Organisation, e.g., E10-E14 for Diabetes. Domain: MedicalCondition; Range: xsd:string.</rdfs:comment>
        <rdfs:label>ICD Code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#institution -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#institution">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The academic institution (university or college) with which a researcher or student is affiliated, e.g., UOS, UET, BZU. Domain: Researcher or Student; Range: xsd:string.</rdfs:comment>
        <rdfs:label>institution</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#licenseNo -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#licenseNo">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The professional license number assigned to a dietitian or healthcare professional by a regulatory authority. Domain: Dietitian; Range: xsd:string.</rdfs:comment>
        <rdfs:label>license No</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#major -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#major">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The academic major or field of study of a researcher or student. Domain: Researcher or Student; Range: xsd:string.</rdfs:comment>
        <rdfs:label>major</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#mealFrequencyPerDay -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#mealFrequencyPerDay">
        <rdfs:domain rdf:resource="http://schema.org/Diet"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The recommended number of meals or eating occasions per day prescribed by a diet plan. Domain: Diet; Range: xsd:integer.</rdfs:comment>
        <rdfs:label>meal Frequency Per Day</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#medicalDegree -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#medicalDegree">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#HealthcareProfessional"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The medical qualification or degree held by a healthcare professional, such as MBBS or MD. Domain: HealthcareProfessional; Range: xsd:string.</rdfs:comment>
        <rdfs:label>medical Degree</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#mineralName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#mineralName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Mineral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The name of the mineral nutrient, such as Calcium, Iron, or Zinc. Domain: Mineral; Range: xsd:string.</rdfs:comment>
        <rdfs:label>mineral Name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#nutrientAmount -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#nutrientAmount">
        <rdfs:domain rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The amount or quantity of a nutrient present in a food item or supplement, expressed with its unit (e.g., 1000mg, 750 mg). Domain: NutritionInformation; Range: xsd:string.</rdfs:comment>
        <rdfs:label>nutrient Amount</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#publicationCount -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#publicationCount">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment>The total number of academic publications authored or co-authored by a researcher, student, or dietitian. Domain: Researcher or Student or Dietitian; Range: xsd:int.</rdfs:comment>
        <rdfs:label>publication Count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendedDailyIntake -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#recommendedDailyIntake">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Micronutrient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The recommended daily intake (RDI) of a micronutrient for a healthy adult, as defined by dietary guidelines. Domain: Micronutrient; Range: xsd:string.</rdfs:comment>
        <rdfs:label>recommended Daily Intake</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#regionName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#regionName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#FoodOrigin"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The name of the specific region within a country associated with a food origin, e.g., Punjab or South Asia. Domain: FoodOrigin; Range: xsd:string.</rdfs:comment>
        <rdfs:label>region Name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#requiresEpipen -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#requiresEpipen">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/GSSO_011756"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Indicates whether the allergy is severe enough to require an epinephrine auto-injector (EpiPen) for emergency treatment. Domain: Allergy; Range: xsd:string.</rdfs:comment>
        <rdfs:label>requires Epipen</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#specialization -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#specialization">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The area of professional specialisation of a dietitian, such as Clinical-Dietitian or Sports-Dietitian. Domain: Dietitian; Range: xsd:string.</rdfs:comment>
        <rdfs:label>specialization</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#studentId -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#studentId">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/AGRO_00000374"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The unique identification number assigned to a student by their academic institution. Each student must have exactly one student ID. Domain: Student; Range: xsd:integer.</rdfs:comment>
        <rdfs:label>student Id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#supplementRecommendation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#supplementRecommendation">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/DOID_5113"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A dietary supplement recommended for managing or treating a deficiency disease, e.g., iron supplements for anemia. Domain: DeficiencyDisease; Range: xsd:string.</rdfs:comment>
        <rdfs:label>supplement Recommendation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#symptomDescription -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#symptomDescription">
        <rdfs:domain rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A textual description of the symptoms associated with a medical condition. Domain: MedicalCondition; Range: xsd:string.</rdfs:comment>
        <rdfs:label>symptom Description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#targetWeightLossKg -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#targetWeightLossKg">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#WeightLossDiet"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The target amount of weight loss in kilograms that a weight loss diet plan aims to achieve. Domain: WeightLossDiet; Range: xsd:string.</rdfs:comment>
        <rdfs:label>target Weight Loss Kg</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#vitaminType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#vitaminType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Micronutrient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The type or classification of a vitamin micronutrient, indicating whether it is fat-soluble (e.g., D3) or water-soluble (e.g., B12, C). Domain: Micronutrient; Range: xsd:string.</rdfs:comment>
        <rdfs:label>vitamin Type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#yearOfExperience -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#yearOfExperience">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The number of years of professional experience of a dietitian in their field. Domain: Dietitian; Range: xsd:integer.</rdfs:comment>
        <rdfs:label>year Of Experience</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/AGRO_00000373 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/AGRO_00000373">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>a person who conduct research</rdfs:comment>
        <rdfs:label>Researcher</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/AGRO_00000374 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/AGRO_00000374">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#studentId"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian"/>
        <rdfs:comment>any student of clg and uni</rdfs:comment>
        <rdfs:label>Student</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/DOID_5113 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_5113">
        <rdfs:subClassOf rdf:resource="http://schema.org/MedicalCondition"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/GSSO_011756"/>
        <rdfs:comment>A disease caused by the lack of an essential nutrient in the diet, such as vitamins or minerals, resulting in conditions like anemia, rickets, or scurvy.</rdfs:comment>
        <rdfs:label>Deficiency Disease</rdfs:label>
        <rdfs:label>Deficiency disease</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/GSSO_011756 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GSSO_011756">
        <rdfs:subClassOf rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:comment>An immune system reaction to a substance (allergen) that is harmless to most people. Examples include pollen allergy, dust allergy, and peanut allergy.</rdfs:comment>
        <rdfs:label>Allergy</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/Diet -->

    <owl:Class rdf:about="http://schema.org/Diet">
        <rdfs:comment>A structured plan of food and drink consumption adopted for health, ethical, or personal reasons. Parent class for all diet types in this ontology.</rdfs:comment>
        <rdfs:label>Diet</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/MedicalCondition -->

    <owl:Class rdf:about="http://schema.org/MedicalCondition">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#icdCode"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A health condition, disease, disorder, or allergy that affects a person and may influence dietary recommendations. Includes chronic diseases, deficiency diseases, and allergies.</rdfs:comment>
        <rdfs:label>Medical Condition</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/NutritionInformation -->

    <owl:Class rdf:about="http://schema.org/NutritionInformation">
        <rdfs:comment>class having information about nutrition</rdfs:comment>
        <rdfs:label>Nutrition Information</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/Person -->

    <owl:Class rdf:about="http://schema.org/Person">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/gender"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/givenName"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>An individual human being who may follow a diet, have a medical condition, or be a healthcare professional, researcher, or student within this ontology.</rdfs:comment>
        <rdfs:label>Person</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/VegetarianDiet -->

    <owl:Class rdf:about="http://schema.org/VegetarianDiet">
        <rdfs:subClassOf rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>A diet that excludes meat and fish, relying primarily on plant-based foods. Includes variants such as lacto-vegetarian, ovo-vegetarian, and vegan diets.</rdfs:comment>
        <rdfs:label>Vegetarian Diet</rdfs:label>
    </owl:Class>
    


    <!-- http://www.ebi.ac.uk/efo/EFO_0009714 -->

    <owl:Class rdf:about="http://www.ebi.ac.uk/efo/EFO_0009714">
        <rdfs:subClassOf rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:comment>A long-lasting medical condition that persists for an extended period and generally cannot be prevented by vaccines or cured by medication. Examples include diabetes and hypertension.</rdfs:comment>
        <rdfs:label>ChronicDisease</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#AnimalBasedFood -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#AnimalBasedFood">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:comment>Food items that are derived from animals, including meat, dairy products, eggs, and other animal-sourced ingredients.</rdfs:comment>
        <rdfs:label>Animal Based Food</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#BalancedDiet -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#BalancedDiet">
        <rdfs:subClassOf rdf:resource="http://schema.org/Diet"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#WeightLossDiet"/>
        <rdfs:comment>A diet that includes appropriate proportions of all essential nutrients including carbohydrates, proteins, fats, vitamins, and minerals to maintain good health.</rdfs:comment>
        <rdfs:label>Balanced Diet</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Dietiatian">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>A qualified healthcare professional who specialises in dietetics, assessing and advising individuals on their nutritional needs and diet plans.</rdfs:comment>
        <rdfs:label>Dietitian</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food">
        <rdfs:comment>eadable items</rdfs:comment>
        <rdfs:label>Food</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#FoodOrigin -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#FoodOrigin">
        <rdfs:comment>Represents the geographical or regional origin of a food item, including the country and region from which the food originates.</rdfs:comment>
        <rdfs:label>Food Origin</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#GeneralPublic -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#GeneralPublic">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>Ordinary members of the public who are not healthcare professionals, researchers, or students; general consumers of dietary information and diet plans.</rdfs:comment>
        <rdfs:label>General Public</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#HealthcareProfessional -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#HealthcareProfessional">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>A licensed medical professional such as a doctor or physician who provides medical care, diagnosis, and treatment to patients.</rdfs:comment>
        <rdfs:label>Healthcare Professional</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Macronutrient -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Macronutrient">
        <rdfs:subClassOf rdf:resource="http://schema.org/NutritionInformation"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Micronutrient"/>
        <rdfs:comment>Nutrients required by the body in large amounts that provide energy, including carbohydrates, proteins, and fats. Measured in grams and providing calories per gram.</rdfs:comment>
        <rdfs:label>Macronutrient</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Micronutrient -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Micronutrient">
        <rdfs:subClassOf rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:comment>Nutrients required by the body in small amounts, including vitamins and some minerals, which are essential for proper physiological function and disease prevention.</rdfs:comment>
        <rdfs:label>Micronutrient</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Mineral -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Mineral">
        <rdfs:subClassOf rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:comment>Inorganic nutrients such as calcium, iron, and zinc that are essential for various bodily functions including bone formation, oxygen transport, and enzyme activity.</rdfs:comment>
        <rdfs:label>Mineral</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#PlantBasedFood -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#PlantBasedFood">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <owl:disjointWith>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#AnimalBasedFood"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#ProcessedFood"/>
                </owl:unionOf>
            </owl:Class>
        </owl:disjointWith>
        <rdfs:comment>Food items that are derived entirely from plant sources, including fruits, vegetables, legumes, grains, nuts, and seeds. Excludes all animal-derived products.</rdfs:comment>
        <rdfs:label>Plant Based Food</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#ProcessedFood -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#ProcessedFood">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Food"/>
        <rdfs:comment>Food items that have been altered from their natural state through industrial processing, including addition of preservatives, artificial flavours, or other chemical modifications.</rdfs:comment>
        <rdfs:label>Processed Food</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Water -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#Water">
        <rdfs:subClassOf rdf:resource="http://schema.org/NutritionInformation"/>
        <rdfs:comment>An essential nutrient and beverage that is vital for all biological processes, hydration, and metabolic functions. Includes drinking water and mineral water varieties.</rdfs:comment>
        <rdfs:label>Water</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#WeightLossDiet -->

    <owl:Class rdf:about="http://www.semanticweb.org/pmyls/ontologies/2026/3/untitled-ontology-42#WeightLossDiet">
        <rdfs:subClassOf rdf:resource="http://schema.org/Diet"/>
        <rdfs:comment>A specialised diet plan designed to reduce body weight by creating a caloric deficit through controlled food intake, including keto, low-calorie, and intermittent fasting approaches.</rdfs:comment>
        <rdfs:label>Weight Loss Diet</rdfs:label>
    </owl:Class>
    


