<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.w3.org/2002/07/owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:sio="http://semanticscience.org/ontology/sio.owl/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:gsso="http://purl.obolibrary.org/obo/gsso.owl/"
     xmlns:mesh="https://w3id.org/biopragmatics/resources/mesh/mesh.ofn/"
     xmlns:ncit="http://purl.obolibrary.org/obo/ncit.owl/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:omrse="http://purl.obolibrary.org/obo/omrse.owl/"
     xmlns:schema="https://schema.org/"
     xmlns:schema1="http://schema.org/"
     xmlns:reproduceme="https://w3id.org/reproduceme/"
     xmlns:untitled-ontology-52="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#">
    <Ontology rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/affiliation -->

    <ObjectProperty rdf:about="http://schema.org/affiliation">
        <rdfs:domain rdf:resource="http://schema.org/Researcher"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ResearchLab"/>
        <rdfs:comment xml:lang="en">Relates a researcher or person to the organization or research lab they are affiliated with.</rdfs:comment>
        <rdfs:label xml:lang="en">Affiliation</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/employee -->

    <ObjectProperty rdf:about="http://schema.org/employee">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://id.nlm.nih.gov/mesh/D005178"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://schema.org/CollegeOrUniversity"/>
        <rdfs:comment xml:lang="en">Relates a faculty or administrative staff member to the university that employs them.</rdfs:comment>
        <rdfs:label xml:lang="en">Employee</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/funder -->

    <ObjectProperty rdf:about="http://schema.org/funder">
        <rdfs:domain rdf:resource="http://schema.org/CollegeOrUniversity"/>
        <rdfs:range rdf:resource="http://schema.org/Grant"/>
        <rdfs:comment xml:lang="en">Relates an organization to the grant or funding body that provides financial support for a project.</rdfs:comment>
        <rdfs:label xml:lang="en">Funder</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/funding -->

    <ObjectProperty rdf:about="http://schema.org/funding">
        <rdfs:domain rdf:resource="https://w3id.org/reproduceme#ResearchProject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ResearchGrant"/>
        <rdfs:comment xml:lang="en">Relates a research project to the research grant that financially supports it.</rdfs:comment>
        <rdfs:label xml:lang="en">Funding</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/hasCourse -->

    <ObjectProperty rdf:about="http://schema.org/hasCourse">
        <rdfs:domain rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <rdfs:range rdf:resource="http://schema.org/Course"/>
        <rdfs:comment xml:lang="en">Relates an educational credential or program to the courses that are part of it.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Course</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/hasCredential -->

    <ObjectProperty rdf:about="http://schema.org/hasCredential">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <rdfs:comment xml:lang="en">Relates a student to the educational credential or qualification they have obtained.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Credential</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/isPartOf -->

    <ObjectProperty rdf:about="http://schema.org/isPartOf">
        <rdfs:domain rdf:resource="http://schema.org/Course"/>
        <rdfs:range rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <rdfs:comment xml:lang="en">Relates a course to the educational program or credential it belongs to.</rdfs:comment>
        <rdfs:label xml:lang="en">Is Part Of</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/isPrerequisiteOf -->

    <ObjectProperty rdf:about="http://schema.org/isPrerequisiteOf">
        <rdfs:domain rdf:resource="http://schema.org/Course"/>
        <rdfs:range rdf:resource="http://schema.org/Course"/>
        <rdfs:comment xml:lang="en">Relates a course that must be completed before another course can be taken.</rdfs:comment>
        <rdfs:label xml:lang="en">Is Prerequisite Of</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/memberOf -->

    <ObjectProperty rdf:about="http://schema.org/memberOf">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://schema.org/Organization"/>
        <rdfs:comment xml:lang="en">Relates a person to the organization or academic unit they are a member of.</rdfs:comment>
        <rdfs:label xml:lang="en">Member Of</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/organizedBy -->

    <ObjectProperty rdf:about="http://schema.org/organizedBy">
        <rdfs:domain rdf:resource="http://schema.org/Event"/>
        <rdfs:range rdf:resource="http://schema.org/CollegeOrUniversity"/>
        <rdfs:comment xml:lang="en">Relates an academic event to the university or organization responsible for organizing it.</rdfs:comment>
        <rdfs:label xml:lang="en">Organized By</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/organizer -->

    <ObjectProperty rdf:about="http://schema.org/organizer">
        <rdfs:domain rdf:resource="http://schema.org/CollegeOrUniversity"/>
        <rdfs:range rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="en">Relates a university or organization to the academic events it organizes.</rdfs:comment>
        <rdfs:label xml:lang="en">Organizer</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/taughtBy -->

    <ObjectProperty rdf:about="http://schema.org/taughtBy">
        <inverseOf rdf:resource="http://schema.org/teaches"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://id.nlm.nih.gov/mesh/D005178"/>
        <rdfs:comment xml:lang="en">Relates a student to the faculty member who teaches them; inverse of teaches.</rdfs:comment>
        <rdfs:label xml:lang="en">Taught By</rdfs:label>
    </ObjectProperty>
    


    <!-- http://schema.org/teaches -->

    <ObjectProperty rdf:about="http://schema.org/teaches">
        <rdfs:domain rdf:resource="http://id.nlm.nih.gov/mesh/D005178"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:comment xml:lang="en">Relates a faculty member to the students they teach in a course or program.</rdfs:comment>
        <rdfs:label xml:lang="en">Teaches</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#awardedTo -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#awardedTo">
        <inverseOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#receives"/>
        <rdfs:domain rdf:resource="http://schema.org/Grant"/>
        <rdfs:range>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCIT_C75561"/>
                    <rdf:Description rdf:about="http://schema.org/Researcher"/>
                </unionOf>
            </Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Relates a grant or scholarship to the student or researcher who receives it.</rdfs:comment>
        <rdfs:label xml:lang="en">Awarded To</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#completedBy -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#completedBy">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCIT_C131902"/>
                    <rdf:Description rdf:about="http://schema.org/EducationalOccupationalCredential"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:comment xml:lang="en">Relates an examination or degree program to the student who has successfully completed it.</rdfs:comment>
        <rdfs:label xml:lang="en">Completed By</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#completesExamination -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#completesExamination">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCIT_C131902"/>
        <rdfs:comment xml:lang="en">Relates a student to the examination they have completed during their academic program.</rdfs:comment>
        <rdfs:label xml:lang="en">Completes Examination</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#enrolledIn -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#enrolledIn">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://schema.org/Course"/>
        <rdfs:comment xml:lang="en">Relates a student to the course in which they are formally registered and participating.</rdfs:comment>
        <rdfs:label xml:lang="en">Enrolled In</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasAcademicRecord -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasAcademicRecord">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicRecord"/>
        <rdfs:comment xml:lang="en">Relates a student to their academic record, such as GPA or transcript, documenting their academic history.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Academic Record</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasEnrolled -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasEnrolled">
        <rdfs:domain rdf:resource="http://schema.org/Course"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:comment xml:lang="en">Relates a course to the students who have enrolled in it.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Enrolled</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasMajorIn -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasMajorIn">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Specialization"/>
        <rdfs:comment xml:lang="en">Relates a student to the academic specialization they have chosen as their major field of study.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Major In</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasRecord -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hasRecord">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Records"/>
        <rdfs:comment xml:lang="en">Relates a student to the official records associated with their academic activities and history.</rdfs:comment>
        <rdfs:label xml:lang="en">Has Record</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hosts -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#hosts">
        <rdfs:domain rdf:resource="http://schema.org/CollegeOrUniversity"/>
        <rdfs:range rdf:resource="http://schema.org/Project"/>
        <rdfs:comment xml:lang="en">Relates a university or college to the research projects or academic events it hosts.</rdfs:comment>
        <rdfs:label xml:lang="en">Hosts</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#managedBy -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#managedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicUnit"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
        <rdfs:comment xml:lang="en">Relates an academic unit such as a department to the administrative staff member who manages it.</rdfs:comment>
        <rdfs:label xml:lang="en">Managed By</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#receives -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#receives">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCIT_C75561"/>
                    <rdf:Description rdf:about="http://schema.org/Researcher"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://schema.org/Grant"/>
        <rdfs:comment xml:lang="en">Relates a student or researcher to the grant or scholarship they receive; inverse of awardedTo.</rdfs:comment>
        <rdfs:label xml:lang="en">Receives</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#submittedTo -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#submittedTo">
        <rdfs:domain rdf:resource="http://schema.org/Thesis"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCIT_C42671"/>
        <rdfs:comment xml:lang="en">Relates a thesis to the academic department to which it has been formally submitted for evaluation.</rdfs:comment>
        <rdfs:label xml:lang="en">Submitted To</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#supervises -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#supervises">
        <rdfs:domain rdf:resource="http://id.nlm.nih.gov/mesh/D005178"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:comment xml:lang="en">Relates a faculty member to the student they supervise for research, thesis, or academic work.</rdfs:comment>
        <rdfs:label xml:lang="en">Supervises</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#worksOnProject -->

    <ObjectProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#worksOnProject">
        <rdfs:domain rdf:resource="http://schema.org/Researcher"/>
        <rdfs:range rdf:resource="https://w3id.org/reproduceme#ResearchProject"/>
        <rdfs:comment xml:lang="en">Relates a researcher to the research project they are actively working on.</rdfs:comment>
        <rdfs:label xml:lang="en">Works On Project</rdfs:label>
    </ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/address -->

    <DatatypeProperty rdf:about="http://schema.org/address">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Organization"/>
                    <rdf:Description rdf:about="http://schema.org/Person"/>
                    <rdf:Description rdf:about="http://schema.org/Place"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The physical or postal address of a person, organization, or place.</rdfs:comment>
        <rdfs:label xml:lang="en">Address</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/amount -->

    <DatatypeProperty rdf:about="http://schema.org/amount">
        <rdfs:domain rdf:resource="http://schema.org/Grant"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">The monetary value or financial amount associated with a grant or scholarship.</rdfs:comment>
        <rdfs:label xml:lang="en">Amount</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/birthDate -->

    <DatatypeProperty rdf:about="http://schema.org/birthDate">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which a person was born, expressed as a date-time value.</rdfs:comment>
        <rdfs:label xml:lang="en">Birth Date</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/competencyRequired -->

    <DatatypeProperty rdf:about="http://schema.org/competencyRequired">
        <rdfs:domain rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The skills, knowledge, or prerequisites required to enroll in or complete an educational credential.</rdfs:comment>
        <rdfs:label xml:lang="en">Competency Required</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/courseCode -->

    <DatatypeProperty rdf:about="http://schema.org/courseCode">
        <rdfs:domain rdf:resource="http://schema.org/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">A unique numeric or alphanumeric identifier assigned to a course within the university system.</rdfs:comment>
        <rdfs:label xml:lang="en">Course Code</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/datePublished -->

    <DatatypeProperty rdf:about="http://schema.org/datePublished">
        <rdfs:domain rdf:resource="http://schema.org/Thesis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which a thesis or academic document was officially published or submitted.</rdfs:comment>
        <rdfs:label xml:lang="en">Date Published</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/description -->

    <DatatypeProperty rdf:about="http://schema.org/description">
        <rdfs:domain rdf:resource="http://schema.org/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description providing details about a course, thesis, or academic entity.</rdfs:comment>
        <rdfs:label xml:lang="en">Description</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/email -->

    <DatatypeProperty rdf:about="http://schema.org/email">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/CollegeOrUniversity"/>
                    <rdf:Description rdf:about="http://schema.org/Person"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The electronic mail address used to contact a person or organization.</rdfs:comment>
        <rdfs:label xml:lang="en">Email</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/endDate -->

    <DatatypeProperty rdf:about="http://schema.org/endDate">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Event"/>
                    <rdf:Description rdf:about="https://w3id.org/reproduceme#ResearchProject"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which an event, program, or research project is scheduled to end or has ended.</rdfs:comment>
        <rdfs:label xml:lang="en">End Date</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/gender -->

    <DatatypeProperty rdf:about="http://schema.org/gender">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The gender identity of a person, recorded as a string value.</rdfs:comment>
        <rdfs:label xml:lang="en">Gender</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/givenName -->

    <DatatypeProperty rdf:about="http://schema.org/givenName">
        <rdfs:domain rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The first name or given name of a person as used in formal identification.</rdfs:comment>
        <rdfs:label xml:lang="en">Given Name</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/inLanguage -->

    <DatatypeProperty rdf:about="http://schema.org/inLanguage">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Course"/>
                    <rdf:Description rdf:about="http://schema.org/Event"/>
                    <rdf:Description rdf:about="http://schema.org/Thesis"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#language"/>
        <rdfs:comment xml:lang="en">The language in which a course, event, or thesis is conducted or written.</rdfs:comment>
        <rdfs:label xml:lang="en">In Language</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/maximumAttendeeCapacity -->

    <DatatypeProperty rdf:about="http://schema.org/maximumAttendeeCapacity">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Event"/>
                    <rdf:Description rdf:about="http://schema.org/Place"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">The maximum number of attendees or students that a place or event can accommodate.</rdfs:comment>
        <rdfs:label xml:lang="en">Maximum Attendee Capacity</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/name -->

    <DatatypeProperty rdf:about="http://schema.org/name">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Course"/>
                    <rdf:Description rdf:about="http://schema.org/Event"/>
                    <rdf:Description rdf:about="http://schema.org/Thesis"/>
                    <rdf:Description rdf:about="https://w3id.org/reproduceme#ResearchProject"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official name of an entity such as a course, event, project, or organization.</rdfs:comment>
        <rdfs:label xml:lang="en">Name</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/numberOfCredits -->

    <DatatypeProperty rdf:about="http://schema.org/numberOfCredits">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Course"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DegreeProgram"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">The number of academic credit hours assigned to a course or degree program.</rdfs:comment>
        <rdfs:label xml:lang="en">Number Of Credits</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/startDate -->

    <DatatypeProperty rdf:about="http://schema.org/startDate">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Event"/>
                    <rdf:Description rdf:about="https://w3id.org/reproduceme#ResearchProject"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which an event, program, or research project begins.</rdfs:comment>
        <rdfs:label xml:lang="en">Start Date</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://schema.org/telephone -->

    <DatatypeProperty rdf:about="http://schema.org/telephone">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://schema.org/Organization"/>
                    <rdf:Description rdf:about="http://schema.org/Person"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The telephone contact number for a person or organization.</rdfs:comment>
        <rdfs:label xml:lang="en">Telephone</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#cgpa -->

    <DatatypeProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#cgpa">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Cumulative Grade Point Average; a measure of a student&apos;s overall academic performance across all semesters.</rdfs:comment>
        <rdfs:label xml:lang="en">CGPA</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#curriculumVersion -->

    <DatatypeProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#curriculumVersion">
        <rdfs:domain rdf:resource="http://id.nlm.nih.gov/mesh/D003479"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">A numeric identifier representing the version of the curriculum document currently in use.</rdfs:comment>
        <rdfs:label xml:lang="en">Curriculum Version</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#employeeId -->

    <DatatypeProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#employeeId">
        <rdfs:domain>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://id.nlm.nih.gov/mesh/D005178"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
                </unionOf>
            </Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">A unique numeric identifier assigned to a faculty or administrative staff member by the university.</rdfs:comment>
        <rdfs:label xml:lang="en">Employee ID</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#examDuration -->

    <DatatypeProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#examDuration">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C131902"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">The duration of an examination, expressed in hours or days, indicating how long students have to complete it.</rdfs:comment>
        <rdfs:label xml:lang="en">Exam Duration</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#gpa -->

    <DatatypeProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#gpa">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#issueDate -->

    <DatatypeProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#issueDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#TranscriptRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date on which an official transcript record or academic document was formally issued.</rdfs:comment>
        <rdfs:label xml:lang="en">Issue Date</rdfs:label>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#studentId -->

    <DatatypeProperty rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#studentId">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">A unique numeric identifier assigned to a student upon enrollment at the university.</rdfs:comment>
        <rdfs:label xml:lang="en">Student ID</rdfs:label>
    </DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://id.nlm.nih.gov/mesh/D003479 -->

    <Class rdf:about="http://id.nlm.nih.gov/mesh/D003479">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Records"/>
        <rdfs:comment xml:lang="en">A structured plan of courses and academic content that defines the educational requirements and learning objectives for a degree or program.</rdfs:comment>
        <rdfs:label>Curriculum</rdfs:label>
    </Class>
    


    <!-- http://id.nlm.nih.gov/mesh/D005178 -->

    <Class rdf:about="http://id.nlm.nih.gov/mesh/D005178">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:comment xml:lang="en">An individual who holds an academic position at a university or college, responsible for teaching, research, and scholarly activities.</rdfs:comment>
        <rdfs:label>FacultyMember</rdfs:label>
    </Class>
    


    <!-- http://id.nlm.nih.gov/mesh/D005257 -->

    <Class rdf:about="http://id.nlm.nih.gov/mesh/D005257">
        <rdfs:subClassOf rdf:resource="http://schema.org/Grant"/>
        <rdfs:comment xml:lang="en">A financial award granted to a student based on merit, need, or other criteria to support their education.</rdfs:comment>
        <rdfs:label>ScholarShip</rdfs:label>
    </Class>
    


    <!-- http://id.nlm.nih.gov/mesh/D059232 -->

    <Class rdf:about="http://id.nlm.nih.gov/mesh/D059232">
        <rdfs:subClassOf rdf:resource="http://id.nlm.nih.gov/mesh/D005178"/>
        <rdfs:comment xml:lang="en">A staff member who assists in laboratory settings, supporting practical sessions and maintaining lab equipment and resources.</rdfs:comment>
        <rdfs:label>LabAssistant</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/GSSO_010256 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/GSSO_010256">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:comment xml:lang="en">A student who is enrolled in an undergraduate academic program working towards a bachelor&apos;s degree.</rdfs:comment>
        <rdfs:label>UndergraduateStudent</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/GSSO_010257 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/GSSO_010257">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C75561"/>
        <rdfs:comment xml:lang="en">A student enrolled in a postgraduate academic program, pursuing a master&apos;s or doctoral degree after completing undergraduate studies.</rdfs:comment>
        <rdfs:label>PostgraduateStudent</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C131902 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C131902">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#EducationEvent"/>
        <rdfs:comment xml:lang="en">A formal assessment administered to students to evaluate their knowledge, understanding, and competency in a subject.</rdfs:comment>
        <rdfs:label>Examination</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C25357 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C25357">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
        <rdfs:comment xml:lang="en">An administrative officer responsible for managing student records, enrollment, academic schedules, and official university documentation.</rdfs:comment>
        <rdfs:label>Registrar</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C37984 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C37984">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicUnit"/>
        <rdfs:comment xml:lang="en">A dedicated space or facility within the university equipped for practical experiments, research activities, or technical training.</rdfs:comment>
        <rdfs:label>Laboratory</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C39327 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C39327">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DegreeProgram"/>
        <rdfs:comment xml:lang="en">An undergraduate academic degree awarded upon successful completion of a three to four year program of study.</rdfs:comment>
        <rdfs:label>BachelorDegree</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C39453 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C39453">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DegreeProgram"/>
        <rdfs:comment xml:lang="en">A postgraduate academic degree awarded upon successful completion of advanced study beyond a bachelor&apos;s degree, typically lasting one to two years.</rdfs:comment>
        <rdfs:label>MasterDegree</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C42671 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C42671">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicUnit"/>
        <rdfs:comment xml:lang="en">An academic subdivision within a university or college that focuses on a specific field of study and manages related courses and faculty.</rdfs:comment>
        <rdfs:label>Department</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C61514 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C61514">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicUnit"/>
        <rdfs:comment xml:lang="en">A constituent academic unit of a university that groups related departments and disciplines under a single administrative body.</rdfs:comment>
        <rdfs:label>College</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C69170 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C69170">
        <rdfs:subClassOf rdf:resource="http://id.nlm.nih.gov/mesh/D005178"/>
        <rdfs:comment xml:lang="en">A senior academic faculty member who holds the highest teaching rank at a university and is engaged in research and instruction.</rdfs:comment>
        <rdfs:label>Professor</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C71335 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C71335">
        <rdfs:subClassOf rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <rdfs:comment xml:lang="en">An academic credential awarded to a student upon successful completion of a specific course of study or training program.</rdfs:comment>
        <rdfs:label>Diploma</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C75552 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C75552">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
        <rdfs:comment xml:lang="en">An administrative support staff member who handles clerical duties such as record keeping, correspondence, and office management.</rdfs:comment>
        <rdfs:label>Clerk</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C75561 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C75561">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
        <rdfs:comment xml:lang="en">An individual who is formally enrolled in an academic institution and is pursuing a course of study or degree program.</rdfs:comment>
        <rdfs:label>Student</rdfs:label>
    </Class>
    


    <!-- http://schema.org/CollegeOrUniversity -->

    <Class rdf:about="http://schema.org/CollegeOrUniversity">
        <rdfs:subClassOf rdf:resource="http://schema.org/Organization"/>
        <rdfs:comment xml:lang="en">An educational institution that provides higher education, including undergraduate and postgraduate degree programs, research opportunities, and academic services.</rdfs:comment>
        <rdfs:label>College Or University</rdfs:label>
    </Class>
    


    <!-- http://schema.org/ConferenceEvent -->

    <Class rdf:about="http://schema.org/ConferenceEvent">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicEvent"/>
        <rdfs:comment xml:lang="en">A formal gathering of academics, researchers, or professionals to present and discuss research findings, innovations, and developments in a field.</rdfs:comment>
        <rdfs:label>Conference Event</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Course -->

    <Class rdf:about="http://schema.org/Course">
        <rdfs:comment xml:lang="en">A structured unit of academic instruction offered by a university that covers a specific subject and contributes to a degree or certificate program.</rdfs:comment>
        <rdfs:label>Course</rdfs:label>
    </Class>
    


    <!-- http://schema.org/EducationalOccupationalCredential -->

    <Class rdf:about="http://schema.org/EducationalOccupationalCredential">
        <rdfs:comment xml:lang="en">A qualification, certificate, or credential awarded to an individual upon completion of an educational program or meeting professional competency standards.</rdfs:comment>
        <rdfs:label>Educational Occupational Credential</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Event -->

    <Class rdf:about="http://schema.org/Event">
        <rdfs:comment xml:lang="en">An organized occurrence or activity that takes place at a specific time and location, such as a lecture, workshop, or conference.</rdfs:comment>
        <rdfs:label>Event</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Grant -->

    <Class rdf:about="http://schema.org/Grant">
        <rdfs:comment xml:lang="en">A financial award provided by an institution or funding body to support research, academic projects, or educational activities.</rdfs:comment>
        <rdfs:label>Grant</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Organization -->

    <Class rdf:about="http://schema.org/Organization">
        <rdfs:comment xml:lang="en">A structured group of people with a common purpose, such as a university, department, or research institute.</rdfs:comment>
        <rdfs:label>Organization</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Person -->

    <Class rdf:about="http://schema.org/Person">
        <rdfs:comment xml:lang="en">An individual human being who may hold a role within the university such as student, faculty member, or administrative staff.</rdfs:comment>
        <rdfs:label>Person</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Place -->

    <Class rdf:about="http://schema.org/Place">
        <rdfs:comment xml:lang="en">A physical location or venue associated with the university, such as a building, classroom, library, or laboratory.</rdfs:comment>
        <rdfs:label>Place</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Project -->

    <Class rdf:about="http://schema.org/Project">
        <rdfs:comment xml:lang="en">A planned undertaking with defined objectives, timelines, and resources, typically carried out for research, development, or academic purposes.</rdfs:comment>
        <rdfs:label>Project</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Researcher -->

    <Class rdf:about="http://schema.org/Researcher">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:comment xml:lang="en">An individual engaged in systematic investigation and scholarly inquiry aimed at advancing knowledge in a particular field of study.</rdfs:comment>
        <rdfs:label>Researcher</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Thesis -->

    <Class rdf:about="http://schema.org/Thesis">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Records"/>
        <rdfs:comment xml:lang="en">A substantial written research document submitted by a student as a requirement for completing a postgraduate degree program.</rdfs:comment>
        <rdfs:label>Thesis</rdfs:label>
    </Class>
    


    <!-- http://semanticscience.org/resource/SIO_000875 -->

    <Class rdf:about="http://semanticscience.org/resource/SIO_000875">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
        <rdfs:comment xml:lang="en">The Head of Department, a senior academic administrator responsible for overseeing the operations, faculty, and academic activities of a specific department.</rdfs:comment>
        <rdfs:label>HOD</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicEvent -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicEvent">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="en">An event organized within or affiliated with an academic institution, such as a conference, workshop, seminar, or lecture.</rdfs:comment>
        <rdfs:label>Academic Event</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicRecord -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicRecord">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Records"/>
        <rdfs:comment xml:lang="en">A formal document or entry that captures a student&apos;s academic performance, grades, and achievements throughout their enrollment.</rdfs:comment>
        <rdfs:label>Academic Record</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicRewards -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicRewards">
        <rdfs:subClassOf rdf:resource="http://schema.org/Grant"/>
        <rdfs:comment xml:lang="en">Incentives or recognition awarded to students or faculty for outstanding academic performance, research contributions, or scholarly achievements.</rdfs:comment>
        <rdfs:label>Academic Rewards</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicUnit -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicUnit">
        <rdfs:subClassOf rdf:resource="http://schema.org/CollegeOrUniversity"/>
        <rdfs:comment xml:lang="en">A structural component of a university responsible for delivering education, such as a department, college, or research center.</rdfs:comment>
        <rdfs:label>Academic Unit</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff">
        <rdfs:subClassOf rdf:resource="http://schema.org/Person"/>
        <rdfs:comment xml:lang="en">Personnel responsible for the non-academic management and operational functions of the university, including clerical and managerial roles.</rdfs:comment>
        <rdfs:label>Administrative Staff</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ArtificialIntelligenceSpecialization -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ArtificialIntelligenceSpecialization">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Specialization"/>
        <disjointWith>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CyberSecuritySpecialization"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DataScienceSpecialization"/>
                </unionOf>
            </Class>
        </disjointWith>
        <rdfs:comment xml:lang="en">A specialized academic track focusing on the study of intelligent systems, machine learning, neural networks, and AI applications.</rdfs:comment>
        <rdfs:label>Artificial Intelligence Specialization</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AssistantProfessor -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AssistantProfessor">
        <rdfs:subClassOf rdf:resource="http://id.nlm.nih.gov/mesh/D005178"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Lecturer"/>
        <rdfs:comment xml:lang="en">A junior faculty member who engages in teaching and research activities, typically at the entry level of the academic professorial rank.</rdfs:comment>
        <rdfs:label>Assistant Professor</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Building -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Building">
        <rdfs:subClassOf rdf:resource="http://schema.org/Place"/>
        <rdfs:comment xml:lang="en">A physical structure on the university campus that houses academic, administrative, or support facilities.</rdfs:comment>
        <rdfs:label>Building</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CertificateProgram -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CertificateProgram">
        <rdfs:subClassOf rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DegreeProgram"/>
        <rdfs:comment xml:lang="en">A short-term academic program designed to provide students with focused skills and knowledge in a specific area, resulting in a certificate award.</rdfs:comment>
        <rdfs:label>Certificate Program</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Classroom -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Classroom">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Building"/>
        <rdfs:comment xml:lang="en">A designated room within a university building used for conducting lectures, tutorials, and other instructional activities.</rdfs:comment>
        <rdfs:label>Classroom</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CoreCourses -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CoreCourses">
        <rdfs:subClassOf rdf:resource="http://schema.org/Course"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ElectiveCourses"/>
        <rdfs:comment xml:lang="en">Mandatory courses that all students in a program must complete, forming the foundational academic requirements of the curriculum.</rdfs:comment>
        <rdfs:label>Core Courses</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CyberSecuritySpecialization -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CyberSecuritySpecialization">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Specialization"/>
        <disjointWith>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ArtificialIntelligenceSpecialization"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DataScienceSpecialization"/>
                </unionOf>
            </Class>
        </disjointWith>
        <rdfs:comment xml:lang="en">A specialized academic track focused on protecting computer systems, networks, and data from digital attacks, breaches, and unauthorized access.</rdfs:comment>
        <rdfs:label>Cyber Security Specialization</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DataScienceSpecialization -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DataScienceSpecialization">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Specialization"/>
        <disjointWith>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ArtificialIntelligenceSpecialization"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CyberSecuritySpecialization"/>
                </unionOf>
            </Class>
        </disjointWith>
        <rdfs:comment xml:lang="en">A specialized academic track that combines statistics, programming, and domain knowledge to extract insights and knowledge from structured and unstructured data.</rdfs:comment>
        <rdfs:label>Data Science Specialization</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Dean -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Dean">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AdministrativeStaff"/>
        <rdfs:comment xml:lang="en">A senior administrative official of a college or faculty within the university, responsible for academic and administrative leadership of their unit.</rdfs:comment>
        <rdfs:label>Dean</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DegreeProgram -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DegreeProgram">
        <rdfs:subClassOf rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <rdfs:comment xml:lang="en">A formal academic program offered by the university that leads to the award of a recognized qualification such as a bachelor&apos;s, master&apos;s, or doctoral degree.</rdfs:comment>
        <rdfs:label>Degree Program</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DoctrateDegree -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DoctrateDegree">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#DegreeProgram"/>
        <rdfs:comment xml:lang="en">The highest academic degree awarded by a university, typically requiring original research, a dissertation, and demonstrated expertise in a specialized field.</rdfs:comment>
        <rdfs:label>Doctorate Degree</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#EducationEvent -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#EducationEvent">
        <rdfs:subClassOf rdf:resource="http://schema.org/Event"/>
        <rdfs:comment xml:lang="en">A structured academic activity such as a lecture, seminar, or workshop organized for the purpose of teaching and learning.</rdfs:comment>
        <rdfs:label>Education Event</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ElectiveCourses -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ElectiveCourses">
        <rdfs:subClassOf rdf:resource="http://schema.org/Course"/>
        <rdfs:comment xml:lang="en">Optional courses that students may choose to complete based on their academic interests, in addition to the mandatory core curriculum.</rdfs:comment>
        <rdfs:label>Elective Courses</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Final -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Final">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C131902"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Mids"/>
        <rdfs:comment xml:lang="en">A comprehensive examination held at the end of an academic semester to assess students&apos; overall understanding of a course.</rdfs:comment>
        <rdfs:label>Final Examination</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#IOTLab -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#IOTLab">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C37984"/>
        <rdfs:comment xml:lang="en">A specialized laboratory facility equipped with Internet of Things devices and infrastructure for hands-on research and experimentation.</rdfs:comment>
        <rdfs:label>IOT Lab</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#InternationalConference -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#InternationalConference">
        <rdfs:subClassOf rdf:resource="http://schema.org/ConferenceEvent"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#NationalConference"/>
        <rdfs:comment xml:lang="en">An academic conference that brings together researchers, scholars, and professionals from multiple countries to share and discuss research findings.</rdfs:comment>
        <rdfs:label>International Conference</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Lecture -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Lecture">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#EducationEvent"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Workshop"/>
        <rdfs:comment xml:lang="en">A formal educational session delivered by a faculty member to students, covering specific topics within a course curriculum.</rdfs:comment>
        <rdfs:label>Lecture</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Lecturer -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Lecturer">
        <rdfs:subClassOf rdf:resource="http://id.nlm.nih.gov/mesh/D005178"/>
        <rdfs:comment xml:lang="en">A faculty member who delivers lectures and course instruction to students, typically holding a teaching-focused academic position.</rdfs:comment>
        <rdfs:label>Lecturer</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Library -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Library">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Building"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ResearchLab"/>
        <rdfs:comment xml:lang="en">A university facility that provides access to books, journals, digital resources, and study spaces to support academic research and learning.</rdfs:comment>
        <rdfs:label>Library</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#MasterStudent -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#MasterStudent">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GSSO_010257"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#PHDStudent"/>
        <rdfs:comment xml:lang="en">A student who is enrolled in a master&apos;s degree program and engaged in advanced academic study beyond the undergraduate level.</rdfs:comment>
        <rdfs:label>Master Student</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#MasterThesis -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#MasterThesis">
        <rdfs:subClassOf rdf:resource="http://schema.org/Thesis"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#PHDThesis"/>
        <rdfs:comment xml:lang="en">A research-based document written by a master&apos;s student as the culminating requirement for earning a master&apos;s degree.</rdfs:comment>
        <rdfs:label>Master Thesis</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#MeritBaseScholarship -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#MeritBaseScholarship">
        <rdfs:subClassOf rdf:resource="http://id.nlm.nih.gov/mesh/D005257"/>
        <disjointWith rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#NeedBaseScholarship"/>
        <rdfs:comment xml:lang="en">A financial award granted to students who demonstrate exceptional academic performance, achievements, or talents.</rdfs:comment>
        <rdfs:label>Merit Based Scholarship</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Mids -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Mids">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C131902"/>
        <rdfs:comment xml:lang="en">A midterm examination administered partway through an academic semester to assess students&apos; progress and understanding of course material.</rdfs:comment>
        <rdfs:label>Midterm Examination</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#NationalConference -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#NationalConference">
        <rdfs:subClassOf rdf:resource="http://schema.org/ConferenceEvent"/>
        <rdfs:comment xml:lang="en">An academic conference organized at the national level where researchers and professionals from within the country present their work.</rdfs:comment>
        <rdfs:label>National Conference</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#NeedBaseScholarship -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#NeedBaseScholarship">
        <rdfs:subClassOf rdf:resource="http://id.nlm.nih.gov/mesh/D005257"/>
        <rdfs:comment xml:lang="en">A financial award provided to students who demonstrate financial hardship or limited economic resources to support their education.</rdfs:comment>
        <rdfs:label>Need Based Scholarship</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#PHDStudent -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#PHDStudent">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GSSO_010257"/>
        <rdfs:comment xml:lang="en">A doctoral student enrolled in a PhD program, engaged in original research under academic supervision towards earning a doctorate degree.</rdfs:comment>
        <rdfs:label>PHD Student</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#PHDThesis -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#PHDThesis">
        <rdfs:subClassOf rdf:resource="http://schema.org/Thesis"/>
        <rdfs:comment xml:lang="en">A comprehensive research document produced by a PhD student presenting original findings as the primary requirement for a doctoral degree.</rdfs:comment>
        <rdfs:label>PHD Thesis</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ProfessionalCertificate -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ProfessionalCertificate">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#CertificateProgram"/>
        <rdfs:comment xml:lang="en">A credential awarded upon completion of a professional development program that validates specific occupational skills and competencies.</rdfs:comment>
        <rdfs:label>Professional Certificate</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Records -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Records">
        <rdfs:comment xml:lang="en">Documentation and data maintained by the university relating to students, staff, courses, and other academic or administrative activities.</rdfs:comment>
        <rdfs:label>Records</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ResearchGrant -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ResearchGrant">
        <rdfs:subClassOf rdf:resource="http://schema.org/Grant"/>
        <rdfs:comment xml:lang="en">Funding awarded to researchers or academic units to support the conduct of specific research projects and scholarly investigations.</rdfs:comment>
        <rdfs:label>Research Grant</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ResearchLab -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#ResearchLab">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C37984"/>
        <rdfs:comment xml:lang="en">A facility within the university dedicated to conducting scientific and academic research activities in a specialized domain.</rdfs:comment>
        <rdfs:label>Research Lab</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Specialization -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Specialization">
        <rdfs:subClassOf rdf:resource="http://schema.org/EducationalOccupationalCredential"/>
        <rdfs:comment xml:lang="en">A focused area of academic study within a broader degree program that allows students to develop expertise in a particular field.</rdfs:comment>
        <rdfs:label>Specialization</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#TranscriptRecord -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#TranscriptRecord">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicRecord"/>
        <rdfs:comment xml:lang="en">An official academic document issued by the university that provides a complete record of a student&apos;s courses, grades, and academic history.</rdfs:comment>
        <rdfs:label>Transcript Record</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Workshop -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#Workshop">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#EducationEvent"/>
        <rdfs:comment xml:lang="en">An interactive educational session focused on practical skills, problem-solving, or collaborative learning on a specific topic.</rdfs:comment>
        <rdfs:label>Workshop</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#gpa -->

    <Class rdf:about="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#gpa">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/muham/ontologies/2026/3/untitled-ontology-52#AcademicRecord"/>
    </Class>
    


    <!-- https://w3id.org/reproduceme#ResearchProject -->

    <Class rdf:about="https://w3id.org/reproduceme#ResearchProject">
        <rdfs:subClassOf rdf:resource="http://schema.org/Project"/>
        <rdfs:comment xml:lang="en">A structured academic initiative undertaken by researchers to investigate a specific problem or question, with defined goals, methodology, and outcomes.</rdfs:comment>
        <rdfs:label>Research Project</rdfs:label>
    </Class>
    


